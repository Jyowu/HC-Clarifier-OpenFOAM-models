FoamFile
{
    format      ascii;
    class       volSymmTensorField;
    location    "0";
    object      R;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform (0.0049 0 0 0.0049 0 0.0049);

boundaryField
{
    bottomoutlet
    {
        type            zeroGradient;
    }
    negyinlet
    {
        type            fixedValue;
        value           uniform (0.0049 0 0 0.0049 0 0.0049);
    }
    posyinlet
    {
        type            fixedValue;
        value           uniform (0.0049 0 0 0.0049 0 0.0049);
    }
    topoutlet
    {
        type            zeroGradient;
    }
    wall
    {
        type            kqRWallFunction;
        value           $internalField;
    }
}


