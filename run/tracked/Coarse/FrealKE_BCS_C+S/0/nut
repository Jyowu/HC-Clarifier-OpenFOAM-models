FoamFile
{
    format      binary;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    bottomoutlet
    {
        type            calculated;
        value           uniform 0;
    }
    negyinlet
    {
        type            calculated;
        value           uniform 0;
    }
    posyinlet
    {
        type            calculated;
        value           uniform 0;
    }
    topoutlet
    {
        type            calculated;
        value           uniform 0;
    }
    wall
    {
        type            nutkWallFunction;
        Cmu             0.09;
        kappa           0.41;
        E               9.8;
        value           uniform 0;
    }
}


