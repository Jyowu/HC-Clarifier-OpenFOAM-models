FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      momentumTransport;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


simulationType  RAS;

RAS
{
    model           realizableKE_BCS;
    turbulence      on;
    printCoeffs     off;

    realizableKE_BCSCoeffs
    {
        A0                  4.0;
        C2                  1.9;
        sigmak              1.0;
        sigmaEps            1.2;

        curvatureCorrection true;
        swirlCorrection     true;
        buoyancyCorrection  true;

        axisOrigin          (0 0 0);
        axisDirection       (0 0 1);

        S0                  0.2;
        S1                  0.8;
        frMax               1.25;
        swirlEps            1e-6;
        Cg                  1.0;
        writeFields         false;
    }
}


